{
	"$schema": "https://schemas.wp.org/trunk/wp-env.json",
	"core": null,
	"plugins": [ "." ],
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": "/var/www/html/wp-content/plugins/onesearch/tests/_output/debug.log"
	},
	"env": {
		"development": {
			"config": {
				"WP_DEVELOPMENT_MODE": "plugin",
				"WP_ENVIRONMENT_TYPE": "development"
			}
		},
		"tests": {
			"config": {
				"FS_METHOD": "direct"
			},
			"mappings": {
				"/wp-content/plugins/onesearch": "."
			}
		}
	},
	"lifecycleScripts": {
		"afterStart": "wp-env run cli wp rewrite structure /%postname%/ --hard && wp-env run tests-cli wp rewrite structure /%postname%/ --hard"
	}
}
