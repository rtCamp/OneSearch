{
	"$schema": "https://schemas.wp.org/trunk/wp-env.json",
	"core": null,
	"testsEnvironment": false,
	"plugins": [ "." ],
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": "/var/www/html/wp-content/plugins/onesearch/tests/_output/debug-test.log"
	},
	"env": {
		"development": {
			"config": {
				"WP_DEVELOPMENT_MODE": "plugin",
				"WP_ENVIRONMENT_TYPE": "development",
				"FS_METHOD": "direct"
			},
			"mappings": {
				"wp-content/plugins/onesearch": "."
			}
		}
	}
}
